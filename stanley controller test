import cv2
import numpy as np
from gpiozero import Servo
from time import sleep

class StanleySystem:
    def __init__(self, k=0.5, max_steer_deg=25):
        self.k = k  # Gain: Higher = sharper turns
        self.max_steer_rad = np.radians(max_steer_deg)
        self.v = 1.0  # Assumed constant velocity (m/s)
        self.meters_per_pixel = 0.002 # CALIBRATION: meters per 1 pixel
        
        # Smoothing filter buffer
        self.window_size = 5
        self.history = []

    def smooth_error(self, error):
        self.history.append(error)
        if len(self.history) > self.window_size:
            self.history.pop(0)
        return sum(self.history) / len(self.history)

    def calculate_steering(self, lane_x, frame_width):
        # Calculate Cross-Track Error (CTE)
        pixel_error = lane_x - (frame_width / 2)
        cte = pixel_error * self.meters_per_pixel
        
        # Apply smoothing
        smooth_cte = self.smooth_error(cte)
        
        # Stanley Formula: delta = heading_error + atan(k * cte / v)
        # We assume heading_error is 0 for basic line following
        heading_error = 0 
        steer_rad = heading_error + np.arctan2(self.k * smooth_cte, self.v)
        
        # Clip to your 25 degree physical limit
        steer_rad = np.clip(steer_rad, -self.max_steer_rad, self.max_steer_rad)
        
        # Map to Servo range (-1.0 to 1.0)
        return steer_rad / self.max_steer_rad

        
